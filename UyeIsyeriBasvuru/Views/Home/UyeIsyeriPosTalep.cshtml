@model UyeIsyeriBasvuru.Models.UyeIsyeriPosTalep

<div class="container-fluid">

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-terminal text-primary mr-2"></i> Üye İşyeri POS Donanım / Tip Talebi Girişi
        </h1>
    </div>

    @* --- BİLDİRİM VE HATA YÖNETİM ALANLARI --- *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle mr-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-exclamation-triangle mr-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @* Akıllı Hata Özet Kutusu (Yalnızca validasyon hatası oluştuğunda tetiklenir) *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger shadow-sm">
            <h6 class="font-weight-bold"><i class="fas fa-ban mr-1"></i> Form Validasyon Hatası:</h6>
            <div asp-validation-summary="All" class="small pl-3"></div>
        </div>
    }

    @* --- POS TALEP FORMU --- *@
    <div class="card shadow mb-4 border-left-primary">
        <div class="card-header py-3 bg-light">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-boxes mr-1"></i> Donanım ve POS Adet Planlama Formu</h6>
        </div>
        <div class="card-body text-dark">

            <form asp-controller="Home" asp-action="UyeIsyeriPosTalep" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group bg-light p-3 rounded border">
                    <label asp-for="BasvuruId" class="font-weight-bold small text-primary">İlişkili CRM Başvuru Kaydı</label>
                    <select asp-for="BasvuruId" class="form-control" asp-items="@(new SelectList(ViewBag.Basvurular, "BasvuruId", "Aciklama"))">
                        <option value="">-- POS Talebinin Bağlanacağı Başvuruyu Seçiniz --</option>
                    </select>
                    <span asp-validation-for="BasvuruId" class="text-danger small"></span>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="PosTipi" class="font-weight-bold small text-secondary"></label>
                        <select asp-for="PosTipi" class="form-control">
                            <option value="">-- POS Tipi Seçiniz --</option>
                            <option value="Fiziki Masaüstü POS">Fiziki Masaüstü POS</option>
                            <option value="Mobil Eft-POS (Yazar Kasa)">Mobil Eft-POS (Yazar Kasa)</option>
                            <option value="Sanal POS (VPOS)">Sanal POS (VPOS)</option>
                            <option value="Android POS / Yeni Nesil">Android POS / Yeni Nesil</option>
                        </select>
                        <span asp-validation-for="PosTipi" class="text-danger small"></span>
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="PosAdedi" class="font-weight-bold small text-secondary"></label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light fas fa-calculator"></span>
                            </div>
                            <input asp-for="PosAdedi" type="number" class="form-control" placeholder="Örn: 1" min="1" max="100" />
                        </div>
                        <span asp-validation-for="PosAdedi" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="Marka" class="font-weight-bold small text-secondary"></label>
                        <input asp-for="Marka" class="form-control" placeholder="Örn: Verifone, Ingenico, Beko" />
                        <span asp-validation-for="Marka" class="text-danger small"></span>
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="UrunModel" class="font-weight-bold small text-secondary"></label>
                        <input asp-for="UrunModel" class="form-control" placeholder="Örn: VX 680, Move 5000" />
                        <span asp-validation-for="UrunModel" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="KurulumAdres" class="font-weight-bold small text-secondary"></label>
                    <textarea asp-for="KurulumAdres" rows="2" class="form-control" placeholder="Cihazın kurulacağı veya Sanal POS'un entegre edileceği fiziki mağaza / web adresi..."></textarea>
                    <span asp-validation-for="KurulumAdres" class="text-danger small"></span>
                </div>

                <hr />

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary px-5 shadow-sm">
                        <i class="fas fa-save mr-1"></i> POS Talebini Kaydet
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>