@model IEnumerable<UyeIsyeriBasvuru.Models.UyeIsyeriBasvuruModel>

<div class="container-fluid">

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h4 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-list text-info mr-2"></i> CRM Başvuru Havuzu
        </h1>
        <a asp-action="UyeIsyeriBasvuru" class="btn btn-sm btn-primary shadow-sm px-3 py-2">
            <i class="fas fa-plus fa-sm mr-1"></i> Yeni Üye İşyeri Başvurusu
        </a>
    </div>

    <div class="card shadow mb-4 border-left-dark">
        <div class="card-header py-3 bg-light d-flex align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-dark"><i class="fas fa-table mr-1"></i> Sistemde Kayıtlı Talepler ve İstihbarat Durumları</h6>
            <span class="badge badge-info border px-3 py-2 font-weight-bold">Toplam: @(Model?.Count() ?? 0) Başvuru</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover m-0 text-dark" style="vertical-align: middle;">
                    <thead class="bg-gradient-light text-secondary small font-weight-bold text-uppercase border-bottom">
                        <tr>
                            <th class="pl-4 border-0">ID</th>
                            <th class="border-0">Başvuru NO</th>
                            <th class="border-0">Firma / Ticari Unvan</th>
                            <th class="border-0">Müşteri Tipi</th>
                            <th class="border-0">Kanal / Tip</th>
                            <th class="border-0">İstihbarat</th>
                            <th class="border-0">Durum</th>
                            <th class="text-center pr-4 border-0" style="width: 160px;">Aksiyonlar</th>
                        </tr>
                    </thead>
                    <tbody class="small">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                // Dinamik olarak atama yapıyoruz ki property yoksa bile derleme hatası fırlatmasın, null dönsün
                                dynamic firma = item.FirmaBilgileri?.FirstOrDefault();
                                dynamic kredibilite = item.KredibiliteIslemleri?.FirstOrDefault();

                                bool hasRisk = false;
                                try { hasRisk = kredibilite?.IsOlumsuzPosIstihbarat ?? false; } catch { }

                                string rowClass = hasRisk ? "table-danger text-danger" : "";

                                <tr class="@rowClass">
                                    <td class="pl-4 font-weight-bold align-middle">#@item.BasvuruId</td>
                                    <td class="align-middle">
                                        <span class="badge badge-light border px-2 py-1 font-weight-bold text-dark shadow-sm">
                                            @item.BasvuruNO
                                        </span>
                                    </td>
                                    <td class="align-middle font-weight-bold">
                                        @(firma?.FirmaUnvan ?? "Belirtilmemiş")
                                    </td>
                                    <td class="align-middle">@item.MusteriTipi</td>
                                    <td class="align-middle">
                                        <span class="text-muted text-uppercase font-weight-bold" style="font-size: 10px;">
                                            @{
                                                // Eğer bu alanlar ana modelde yoksa firma modeli üzerinden veya varsayılan değerle geçiştiriyoruz
                                                string kanal = "";
                                                string tip = "";
                                                try { kanal = firma?.BasvuruKanali ?? "Belirtilmemiş"; } catch { }
                                                try { tip = firma?.IsyeriTipi ?? "Belirtilmemiş"; } catch { }
                                                @($"{kanal} / {tip}")
                                            }
                                        </span>
                                    </td>
                                    <td class="align-middle">
                                        @if (hasRisk)
                                        {
                                            <span class="badge badge-danger font-weight-bold text-white shadow-sm px-2 py-1 animate-pulse">
                                                <i class="fas fa-exclamation-triangle"></i> RİSKLİ
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success text-white px-2 py-1">
                                                <i class="fas fa-check"></i> Temiz
                                            </span>
                                        }
                                    </td>
                                    <td class="align-middle">
                                        @if (item.BasvuruDurumu == "Onaylandı")
                                        {
                                            <span class="badge badge-success px-2 py-1 font-weight-bold shadow-sm">
                                                <i class="fas fa-check-circle mr-1"></i> @item.BasvuruDurumu
                                            </span>
                                        }
                                        else if (item.BasvuruDurumu == "Reddedildi")
                                        {
                                            <span class="badge badge-danger px-2 py-1 font-weight-bold shadow-sm" title="Neden: @item.RedNedeni">
                                                <i class="fas fa-times-circle mr-1"></i> Red
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning px-2 py-1 font-weight-bold text-dark shadow-sm">
                                                <i class="fas fa-clock mr-1"></i> @item.BasvuruDurumu
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center pr-4 align-middle">
                                        <div class="d-flex justify-content-center align-items-center style-gap" style="gap: 8px;">
                                            <a asp-action="BasvuruDetay" asp-route-id="@item.BasvuruId" class="btn btn-sm btn-info text-white shadow-sm font-weight-bold px-3">
                                                <i class="fas fa-folder-open mr-1"></i> İncele
                                            </a>

                                            <form asp-action="BasvuruSil" asp-controller="Home" method="post" onsubmit="return confirm('Bu başvuruyu sildiğinizde bağlı olan Firma, Yetkili, Banka, POS ve İstihbarat verileri de KALICI OLARAK silinecektir! Onaylıyor musunuz?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.BasvuruId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" title="Tüm İlişkili Kayıtları Sil">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5 bg-light">
                                    <i class="fas fa-folder-open d-block mb-3 fa-3x text-gray-400"></i>
                                    <span class="font-weight-bold">Sistemde henüz kayıtlı üye işyeri başvurusu bulunmamaktadır.</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>