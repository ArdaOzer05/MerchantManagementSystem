@model UyeIsyeriBasvuru.Models.UyeIsyeriCalismaSarti

<div class="container-fluid">

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-file-contract text-success mr-2"></i> Ticari Çalışma Şartları Yapılandırması
        </h1>
    </div>

    @* --- HATA BİLDİRİMLERİ --- *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger shadow-sm">
            <h6 class="font-weight-bold"><i class="fas fa-exclamation-triangle mr-1"></i> Finansal Koşul Hataları:</h6>
            <div asp-validation-summary="All" class="small pl-3"></div>
        </div>
    }

    <div class="card shadow mb-4 border-left-success">
        <div class="card-header py-3 bg-light d-flex flex-row align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-percentage mr-1"></i> VakıfBank & World Komisyon ve Valör Protokolü</h6>
        </div>
        <div class="card-body text-dark">
            <form asp-controller="Home" asp-action="UyeIsyeriCalismaSarti" method="post">
                @Html.AntiForgeryToken()

                @* Üst Grup: Başvuru Bağlantısı ve Marka Seçimi *@
                <div class="form-row">
                    <div class="form-group col-md-5">
                        <label asp-for="BasvuruId" class="font-weight-bold small text-primary">CRM Başvuru Havuzu</label>
                        <select asp-for="BasvuruId" class="form-control text-dark" asp-items="@(new SelectList(ViewBag.Basvurular, "BasvuruId", "Aciklama"))">
                            <option value="">-- Başvuru Seçiniz --</option>
                        </select>
                        <span asp-validation-for="BasvuruId" class="text-danger small"></span>
                    </div>

                    <div class="form-group col-md-4">
                        <label asp-for="MarkaPaylasimTipi" class="font-weight-bold small text-secondary"></label>
                        <div class="d-flex align-items-center pt-2">
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" asp-for="MarkaPaylasimTipi" value="Vakıfbank İşyeri" id="rbVakif" class="custom-control-input" checked />
                                <label class="custom-control-label" for="rbVakif"><i class="fas fa-building mr-1"></i> VakıfBank</label>
                            </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" asp-for="MarkaPaylasimTipi" value="World İşyeri" id="rbWorld" class="custom-control-input" />
                                <label class="custom-control-label" for="rbWorld"><i class="fas fa-globe-europe mr-1"></i> World Üye İşyeri</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-group col-md-3">
                        <label class="font-weight-bold small text-secondary">Ödeme Kapsamı</label>
                        <div class="custom-control custom-checkbox pt-2">
                            <input type="checkbox" asp-for="IsTaksitSecim" class="custom-control-input" id="chkTaksit" onchange="toggleTaksitSection()">
                            <label class="custom-control-label font-weight-bold text-danger" for="chkTaksit">Taksit Kampanyası Aktif</label>
                        </div>
                    </div>
                </div>

                <hr class="sidebar-divider" />

                @* TEK ÖDEME (DEBİT/CASH) KOŞULLARI *@
                <div class="bg-light p-3 rounded mb-4">
                    <h6 class="text-success font-weight-bold mb-3"><i class="fas fa-coins mr-1"></i> Tek Ödeme (Peşin) Koşulları</h6>
                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label asp-for="TekOdemeCalismaSekli" class="small font-weight-bold"></label>
                            <select asp-for="TekOdemeCalismaSekli" class="form-control text-dark">
                                <option value="Ertesi Gün (Standart)">Ertesi Gün Hesaba Geçiş</option>
                                <option value="Blokeli Çalışma">Blokeli Gün Sayısı Bazlı</option>
                                <option value="Komisyonlu Valör">Valörlü / Komisyon Kesintili</option>
                            </select>
                            <span asp-validation-for="TekOdemeCalismaSekli" class="text-danger small"></span>
                        </div>

                        <div class="form-group col-md-4">
                            <label asp-for="TekOdemePuanOrani" class="small font-weight-bold"></label>
                            <div class="input-group">
                                <input asp-for="TekOdemePuanOrani" type="number" step="0.001" class="form-control text-dark" placeholder="0.000" />
                                <div class="input-group-append"><span class="input-group-text">%</span></div>
                            </div>
                            <span asp-validation-for="TekOdemePuanOrani" class="text-danger small"></span>
                        </div>

                        <div class="form-group col-md-4">
                            <label class="small font-weight-bold text-muted">Özel Tarife Sicil Onayı</label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <div class="input-group-text">
                                        <input type="checkbox" asp-for="IsOzelYetkiFlag" id="chkOzelYetki" onchange="toggleSicilInput()">
                                    </div>
                                </div>
                                <input asp-for="OzelYetkiVerenSicil" class="form-control text-dark" id="txtSicil" placeholder="Onaylayan Müdür Sicili" disabled />
                            </div>
                            <span asp-validation-for="OzelYetkiVerenSicil" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                @* TAKSİTLİ ÖDEME KOŞULLARI (DİNAMİK BÖLÜM) *@
                <div class="bg-light p-3 rounded mb-4 shadow-sm border-left-danger" id="secTaksit" style="display: none;">
                    <h6 class="text-danger font-weight-bold mb-3"><i class="fas fa-credit-card mr-1"></i> World Taksitli Ödeme Koşulları Yapılandırması</h6>
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="TaksitliCalismaSekli" class="small font-weight-bold"></label>
                            <select asp-for="TaksitliCalismaSekli" class="form-control text-dark">
                                <option value="Müteakip Gün Blokeli">Müteakip Gün Blokeli (Önerilen)</option>
                                <option value="Dilimli Geri Ödeme">Dilimli Geri Ödeme Modeli</option>
                                <option value="Firma Ödemeli Komisyon">Firma Ödemeli Peşin Komisyon</option>
                            </select>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="TaksitliPuanOrani" class="small font-weight-bold"></label>
                            <div class="input-group">
                                <input asp-for="TaksitliPuanOrani" type="number" step="0.001" class="form-control text-dark" placeholder="0.000" />
                                <div class="input-group-append"><span class="input-group-text">%</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-success px-5 shadow">
                        <i class="fas fa-check-circle mr-1"></i> Çalışma Şartlarını Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* --- ARAYÜZ ETKİLEŞİM JAVASCRIPT KODLARI --- *@
<script>
    function toggleTaksitSection() {
        var isChecked = document.getElementById("chkTaksit").checked;
        var section = document.getElementById("secTaksit");
        section.style.display = isChecked ? "block" : "none";
    }

    function toggleSicilInput() {
        var isChecked = document.getElementById("chkOzelYetki").checked;
        document.getElementById("txtSicil").disabled = !isChecked;
        if(!isChecked) { document.getElementById("txtSicil").value = ""; }
    }

    // Sayfa ilk yüklendiğinde durumları kontrol et
    document.addEventListener("DOMContentLoaded", function() {
        toggleTaksitSection();
        toggleSicilInput();
    });
</script>